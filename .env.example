# Copy to .env for local runs; do not commit real secrets.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hashisignal
REDIS_URL=redis://redis:6379/0
ENGINE_MODE=replay
DEFAULT_SYMBOL=ETHUSDT
LEVERAGE=1
TAKER_FEE_RATE=0.0006
REPLAY_ORDER_QTY=1.0
REPLAY_MAX_BARS_IN_TRADE=500
LIVE_SAFETY_ENABLED=false
KILL_SWITCH_MODE=off
KILL_SWITCH_AUTO=true
KILL_SWITCH_STALE_MS=2500
KILL_SWITCH_MAX_ERROR_RATE=0.2
KILL_SWITCH_MAX_CONSEC_ERRORS=5
GOV_MAX_TRADES_PER_DAY=999999
GOV_MAX_DAILY_LOSS_PCT=100
GOV_MAX_GLOBAL_DD_PCT=100
GOV_MAX_CONSECUTIVE_LOSSES=3
GOV_MAX_CONSEC_LOSSES_SCOPE=daily
GOV_COOLDOWN_MINUTES=10
GOV_DAILY_LOCK_ON_BREACH=true
GOV_EMERGENCY_UNREALIZED_PCT=100
GOV_MAX_POSITION_HOLD_SECS=999999
INCIDENT_RING_SIZE=500
INCIDENT_SNAPSHOT_ON_KILL=true
TRADING_DAY_TZ=UTC
EXEC_VENUE=mock
EXEC_ROLE=taker
EQUITY_START=100000
MONTHLY_TARGET_PCT=6.0
STRATEGY_PROFILE=TREND_STABLE
EMA_FAST=20
EMA_SLOW=50
ATR_LEN=14
REGIME_TREND_MIN=0.8
PULLBACK_LOOKBACK=10
SCORE_MIN=65
TIME_STOP_BARS=120
TP1_R_MULT=1.0
TP2_R_MULT=1.8
PARTIAL_PCT=0.5
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
