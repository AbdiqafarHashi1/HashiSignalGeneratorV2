# Copy to .env for local runs; do not commit real secrets.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/hashisignal
REDIS_URL=redis://redis:6379/0
ENGINE_MODE=replay
DEFAULT_SYMBOL=ETHUSDT
LEVERAGE=1
TAKER_FEE_RATE=0.0006
REPLAY_ORDER_QTY=1.0
REPLAY_MAX_BARS_IN_TRADE=500
REPLAY_DATASET_DEFAULT=data/datasets/ETHUSDT_15m.csv
NEXT_PUBLIC_REPLAY_DATASET_DEFAULT=data/datasets/ETHUSDT_15m.csv
LIVE_SAFETY_ENABLED=false
KILL_SWITCH_MODE=off
KILL_SWITCH_AUTO=true
KILL_SWITCH_STALE_MS=2500
KILL_SWITCH_MAX_ERROR_RATE=0.2
KILL_SWITCH_MAX_CONSEC_ERRORS=5
GOV_MAX_TRADES_PER_DAY=999999
GOV_MAX_DAILY_LOSS_PCT=100
GOV_MAX_GLOBAL_DD_PCT=100
GOV_MAX_CONSECUTIVE_LOSSES=3
GOV_MAX_CONSEC_LOSSES_SCOPE=daily
GOV_COOLDOWN_MINUTES=10
GOV_DAILY_LOCK_ON_BREACH=true
GOV_EMERGENCY_UNREALIZED_PCT=100
GOV_MAX_POSITION_HOLD_SECS=999999
INCIDENT_RING_SIZE=500
INCIDENT_SNAPSHOT_ON_KILL=true
TRADING_DAY_TZ=UTC
EXEC_VENUE=mock
EXEC_ROLE=taker
EQUITY_START=100000
MONTHLY_TARGET_PCT=6.0
STRATEGY_PROFILE=TREND_STABLE
# Profile overrides apply after env load.
# Valid ACTIVE_PROFILE values: TREND_STABLE, GROWTH_HUNTER, PROP_HUNTER
ACTIVE_PROFILE=TREND_STABLE
EMA_FAST=20
EMA_SLOW=50
ATR_LEN=14
REGIME_TREND_MIN=0.8
PULLBACK_LOOKBACK=10
SCORE_MIN=65
TIME_STOP_BARS=120
TP1_R_MULT=1.0
TP2_R_MULT=1.8
PARTIAL_PCT=0.5
# Regime gate
ATR_PCT_MIN=0.18
HTF_SLOPE_LOOKBACK_BARS=8
HTF_SLOPE_MIN_PCT=0.0020
ADX_LEN=14
ADX_MIN=18
CHOP_LOOKBACK=48
CHOP_MIN_RATIO=0.55
ATR_REGIME_LOOKBACK=96
ATR_EXPAND_MIN=1.08
REGIME_REQUIRE_HTF=false
REGIME_HTF_TIMEFRAME=4h
REGIME_MIN_LTF_BARS=250
REGIME_ALLOW_LTF_FALLBACK=true
FEATURE_BREAKOUT=false
FEATURE_PULLBACK_V2=false
FEATURE_VOL_SIZING=false
BRK_LOOKBACK=64
BRK_MAX_RANGE_ATR=1.8
BRK_MIN_BARS_IN_BOX=20
BRK_CONFIRM_CLOSE=true
BRK_ENTRY_BUFFER_ATR=0.10
BRK_STOP_ATR=1.2
BRK_TP1_R=1.2
BRK_TP2_R=3.0
BRK_RECENT_WINDOW=12
PB2_MIN_IMPULSE_ATR=1.2
PB2_MAX_RETRACE=0.65
PB2_MIN_RETRACE=0.25
PB2_REQUIRE_HL_LH=true
PB2_CONFIRM_BAR=true
PB2_PIVOT_LEN=3
VOL_SIZING_MIN_MULT=0.35
VOL_SIZING_MAX_MULT=1.30
VOL_SIZING_ATR_PCT_LOW=0.18
VOL_SIZING_ATR_PCT_HIGH=0.60
VOL_SIZING_CHOP_PENALTY=0.70
VOL_SIZING_TREND_BONUS=1.10
VOL_SIZING_ENABLE_CAP=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
